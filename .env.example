# ─── Curated — environment ───
# The whole site runs with NO keys (zero-key demo). These ONLY upgrade the experience.

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Analytics (affiliate-click is the conversion proxy) — GA4 or Plausible, configurable
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Monetization — layered offer resolution (resolveBestOffer picks the winner)
SOVRN_AFFILIATE_ID=            # default breadth, solves cold-start
SKIMLINKS_PUBLISHER_ID=
# Amazon PA-API is GATED by the 3-sale rule; absent creds = graceful no-op (Amazon offers hidden)
AMAZON_PA_API_KEY=
AMAZON_PA_API_SECRET=
AMAZON_ASSOCIATES_TAG=
SHAREASALE_AFFILIATE_ID=
IMPACT_ACCOUNT_SID=

# LLM (model-agnostic) — propose / enrich / narrate. Absent = deterministic greedy composer.
LLM_PROVIDER=                  # e.g. anthropic
LLM_API_KEY=

# Vision — visual search + image tagging. Absent = "vibe match" fallback.
VISION_PROVIDER=
VISION_API_KEY=

# Database (Postgres in prod; SQLite for local). Demo reads data/seed-bundles.json directly.
DATABASE_URL=
